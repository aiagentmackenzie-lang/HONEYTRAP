[Unit]
Description=HONEYTRAP AI Emulator
Documentation=https://github.com/aiagentmackenzie-lang/HONEYTRAP
After=network.target
Wants=ollama.service

[Service]
Type=simple
User=honeytrap
Group=honeytrap
WorkingDirectory=/opt/honeytrap/ai_emulator
ExecStart=/usr/bin/python3 server.py 8443
Environment=OLLAMA_BASE_URL=http://localhost:11434
Environment=OLLAMA_MODEL=llama3.2:3b
Restart=on-failure
RestartSec=10

# Security
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=honeytrap-ai

[Install]
WantedBy=multi-user.target