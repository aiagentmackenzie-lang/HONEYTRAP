[Unit]
Description=HONEYTRAP Fastify API Server
Documentation=https://github.com/aiagentmackenzie-lang/HONEYTRAP
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=honeytrap
Group=honeytrap
WorkingDirectory=/opt/honeytrap/api
ExecStart=/usr/bin/node dist/index.js
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOST=0.0.0.0
Restart=on-failure
RestartSec=5

# Security
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=honeytrap-api

[Install]
WantedBy=multi-user.target